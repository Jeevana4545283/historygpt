# Port to run the server on
PORT=5000

# OpenRouter API Key for Chat Models (e.g. sk-or-v1-...)
OPENROUTER_API_KEY=your_openrouter_api_key_here

# OpenRouter Model identifier (defaults to google/gemma-4-31b-it:free if left blank)
LLM_MODEL=google/gemma-4-31b-it:free

# Google Gemini API Key for Embeddings (e.g. AIzaSy...)
GEMINI_API_KEY=your_gemini_api_key_here
